<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
             x:Class="RPGGame.UI.Avalonia.Settings.CombatAndEnemyTuningSettingsPanel"
             Classes="settings-ui"
             Background="Transparent">
    <TabControl x:Name="CombatEnemyTabControl">
        <TabItem Header="Combat">
            <ContentControl x:Name="CombatHost"/>
        </TabItem>
        <TabItem Header="Enemy">
            <ContentControl x:Name="EnemyHost"/>
        </TabItem>
    </TabControl>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:RPGGame.UI.Avalonia.Settings.ViewModels"
             xmlns:settings="clr-namespace:RPGGame.UI.Avalonia.Settings"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
             x:Class="RPGGame.UI.Avalonia.Settings.CombatTuningSettingsPanel"
             Classes="settings-ui"
             Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="CombatTuningRowTemplate" x:DataType="vm:CombatTuningParameterViewModel">
            <Grid ColumnDefinitions="250,*,280" Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="{Binding Label}" Classes="settings-field-label"
                           FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding DisplayAffects}" Classes="setting-example"
                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                <Grid Grid.Column="2" ColumnDefinitions="*,80" VerticalAlignment="Center">
                    <Slider Grid.Column="0" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}"
                            TickFrequency="{Binding TickFrequency}" Value="{Binding Value, Mode=TwoWay}"
                            VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="75" Height="28"
                             Margin="5,0,0,0" FontSize="14" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CombatTuningSubGroupTemplate" x:DataType="vm:CombatTuningSubGroupViewModel">
            <Expander Header="{Binding DisplayName}" IsExpanded="True" Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding Parameters}" ItemTemplate="{StaticResource CombatTuningRowTemplate}"/>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="StandardTuningTabTemplate">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="{Binding ActiveBalancePatchLabel}" Classes="settings-muted" TextWrapping="Wrap"
                   Margin="20,8,20,4" FontSize="13"/>
    <TabControl x:Name="CombatTuningTabControl">
        <TabItem Header="Parameters">
            <TabControl x:Name="ParametersInnerTabControl">
                <TabItem Header="Core">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CoreSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Hero &amp; Classes">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HeroSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Speed &amp; Defense">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SpeedSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Equipment">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EquipmentSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Enemy Stats">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20" Spacing="8">
                            <TextBlock Text="Enemy spawn variance and difficulty presets. Progression curve knobs (tempo, shape, parity) and HP curve preview live on the Progression Curve tab."
                                       Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding EnemySubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Progression Curve" x:Name="ProgressionCurveTabItem">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20" Spacing="16">
                            <TextBlock Classes="settings-section-header" Text="Progression curve knobs"/>
                            <TextBlock Classes="settings-muted" TextWrapping="Wrap"
                                       Text="Tempo stretches enemy HP at all levels (fight length). Shape controls where HP accumulates — early (base) vs late (growth). Parity shifts hero vs enemy survivability without changing curve shape. Base/growth scales are the intercept and slope inputs. Decade rows show derived HP; after a fundamentals sim run, last session combined actions and win rate appear."/>
                            <settings:ProgressionCurvePreviewControl x:Name="ProgressionPreviewControl"
                                                                       PreviewModel="{Binding ProgressionPreview}"/>
                            <Border Background="#FF252525" CornerRadius="4" Padding="8" BorderBrush="#FF444444" BorderThickness="1">
                                <Grid ColumnDefinitions="50,80,80,80,100,80" RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Lvl" Classes="settings-field-label" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Growth Wt" Classes="settings-field-label" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Goblin HP" Classes="settings-field-label" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Player HP" Classes="settings-field-label" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Sim combined" Classes="settings-field-label" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Sim WR" Classes="settings-field-label" FontSize="12"/>
                                    <ItemsControl Grid.Row="1" Grid.ColumnSpan="6" ItemsSource="{Binding ProgressionPreview.DecadeRows}" Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ProgressionCurveAnchorRowViewModel">
                                                <Grid ColumnDefinitions="50,80,80,80,100,80" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding Level}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding GrowthWeightText}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding EnemyHpText}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding PlayerHpText}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding SimCombinedText}"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding SimWinRateText}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding ProgressionCurveSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Archetypes">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Archetype" VerticalAlignment="Center" Classes="settings-field-label"/>
                                <ComboBox MinWidth="180" ItemsSource="{Binding ArchetypeTuning.ArchetypeNames}"
                                          SelectedItem="{Binding ArchetypeTuning.SelectedArchetype, Mode=TwoWay}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ArchetypeTuning.SelectedParameters}"
                                          ItemTemplate="{StaticResource CombatTuningRowTemplate}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Status Effects">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20" Spacing="16">
                            <Expander Header="Global Scaling" IsExpanded="True">
                                <ItemsControl ItemsSource="{Binding StatusEffectTuning.GlobalParameters}"
                                              ItemTemplate="{StaticResource CombatTuningRowTemplate}"/>
                            </Expander>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Effect" VerticalAlignment="Center" Classes="settings-field-label"/>
                                <ComboBox MinWidth="140" ItemsSource="{Binding StatusEffectTuning.EffectNames}"
                                          SelectedItem="{Binding StatusEffectTuning.SelectedEffect, Mode=TwoWay}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding StatusEffectTuning.SelectedEffectParameters}"
                                          ItemTemplate="{StaticResource CombatTuningRowTemplate}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Rewards &amp; Loot">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RewardsSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Goals &amp; Analysis">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GoalsAnalysisSubGroups}" ItemTemplate="{StaticResource CombatTuningSubGroupTemplate}" Margin="20"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </TabItem>

        <TabItem Header="Simulation">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="24" Margin="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick balance simulation" Classes="settings-section-header"/>
                        <TextBlock Text="Runs all weapon vs enemy matchups using current in-memory tuning. Results include win rate, turn length, coefficient of variation, and quality score."
                                   Classes="settings-muted"/>
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Battles/matchup" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimBattlesPerComboTextBox" Grid.Column="1" Width="72" Text="50" Margin="0,0,16,0" Classes="SimParamBox"/>
                            <TextBlock Grid.Column="2" Text="Player level" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimPlayerLevelTextBox" Grid.Column="3" Width="48" Text="1" Margin="0,0,16,0" Classes="SimParamBox"/>
                            <TextBlock Grid.Column="4" Text="Enemy level" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimEnemyLevelTextBox" Grid.Column="5" Width="48" Text="1" Classes="SimParamBox"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="RunSimulationButton" Content="Run simulation" MinWidth="140" Classes="settings-primary-button"/>
                            <TextBlock x:Name="SimStatusTextBlock" VerticalAlignment="Center" Classes="settings-muted"/>
                        </StackPanel>
                        <ProgressBar x:Name="SimProgressBar" IsVisible="False" Minimum="0" Maximum="100" Height="8"/>
                        <TextBox x:Name="SimOutputTextBox" IsReadOnly="True" MinHeight="200" MaxHeight="360"
                                 Classes="settings-console-output" Watermark="Simulation results appear here…"/>
                    </StackPanel>
                    <TextBlock Text="Use Save at the bottom of Settings to write TuningConfig.json." Classes="settings-muted"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
    </StackPanel>
</UserControl>

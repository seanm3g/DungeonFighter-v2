<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
             x:Class="RPGGame.UI.Avalonia.Settings.CombatTuningSettingsPanel"
             Classes="settings-ui"
             Background="Transparent">
    <TabControl x:Name="CombatTuningTabControl">
        <TabItem Header="Parameters">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="24" Margin="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Layered balance controls wired to TuningConfig.json and runtime difficulty (GameSettings). Enemy baselines and global multipliers live here; progression scales and spawn tier weights are in Enemy Tuning."
                                   Classes="settings-muted"/>
                        <TextBlock Text="Save settings to persist the balance patch. New enemies use updated values immediately; the current encounter enemy updates on next spawn."
                                   Classes="settings-muted"/>
                    </StackPanel>

                    <Expander x:Name="DurationExpander" IsExpanded="True" Header="1 — Combat duration (HP / turns)">
                        <StackPanel x:Name="DurationLayerPanel" Spacing="14" Margin="0,8,0,0"/>
                    </Expander>

                    <Expander x:Name="WinRateExpander" Header="2 — Win rate (damage / armor)">
                        <StackPanel x:Name="WinRateLayerPanel" Spacing="14" Margin="0,8,0,0"/>
                    </Expander>

                    <Expander x:Name="RollFeelExpander" Header="3 — Roll feel (variance)">
                        <StackPanel x:Name="RollFeelLayerPanel" Spacing="14" Margin="0,8,0,0"/>
                    </Expander>

                    <Expander x:Name="ComboExpander" Header="4 — Combo affordance">
                        <StackPanel x:Name="ComboLayerPanel" Spacing="14" Margin="0,8,0,0"/>
                    </Expander>

                    <Expander x:Name="GoalsExpander" Header="5 — Tuning goals (simulation targets)">
                        <StackPanel x:Name="GoalsLayerPanel" Spacing="14" Margin="0,8,0,0"/>
                    </Expander>

                    <TextBlock Text="Use Save at the bottom of Settings to write TuningConfig.json."
                               Classes="settings-muted"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Simulation">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="24" Margin="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick balance simulation"
                                   Classes="settings-section-header"/>
                        <TextBlock Text="Runs all weapon vs enemy matchups using current in-memory tuning. Results include win rate, turn length, coefficient of variation, and quality score."
                                   Classes="settings-muted"/>
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Battles/matchup" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimBattlesPerComboTextBox" Grid.Column="1" Width="72" Text="50" Margin="0,0,16,0" Classes="SimParamBox"/>
                            <TextBlock Grid.Column="2" Text="Player level" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimPlayerLevelTextBox" Grid.Column="3" Width="48" Text="1" Margin="0,0,16,0" Classes="SimParamBox"/>
                            <TextBlock Grid.Column="4" Text="Enemy level" VerticalAlignment="Center" Classes="settings-field-label" Margin="0,0,8,0"/>
                            <TextBox x:Name="SimEnemyLevelTextBox" Grid.Column="5" Width="48" Text="1" Classes="SimParamBox"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="RunSimulationButton"
                                    Content="Run simulation"
                                    MinWidth="140"
                                    Classes="settings-primary-button"/>
                            <TextBlock x:Name="SimStatusTextBlock"
                                       VerticalAlignment="Center"
                                       Classes="settings-muted"/>
                        </StackPanel>
                        <ProgressBar x:Name="SimProgressBar"
                                     IsVisible="False"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="8"/>
                        <TextBox x:Name="SimOutputTextBox"
                                 IsReadOnly="True"
                                 MinHeight="200"
                                 MaxHeight="360"
                                 Classes="settings-console-output"
                                 Watermark="Simulation results appear here…"/>
                    </StackPanel>

                    <TextBlock Text="Use Save at the bottom of Settings to write TuningConfig.json."
                               Classes="settings-muted"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>

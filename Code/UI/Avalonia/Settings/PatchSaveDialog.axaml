<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="260"
        x:Class="RPGGame.UI.Avalonia.Settings.PatchSaveDialog" Classes="settings-ui"
        Title="Save config patch"
        Width="560" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="#FF1A1A1A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   Text="Save patch"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FFD700"
                   Margin="0,0,0,12"/>

        <TextBlock x:Name="MessageTextBlock"
                   Grid.Row="1"
                   Text="Choose how to save this patch."
                   FontSize="15"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,16,0,0">
            <Button x:Name="UpdateButton"
                    Content="Update patch"
                    MinWidth="120"
                    Height="35"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#FF0078D4"
                    BorderThickness="0"
                    CornerRadius="4"/>
            <Button x:Name="SaveAsButton"
                    Content="Save as new…"
                    MinWidth="120"
                    Height="35"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#FF2E7D32"
                    BorderThickness="0"
                    CornerRadius="4"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    MinWidth="90"
                    Height="35"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#FF555555"
                    BorderThickness="0"
                    CornerRadius="4"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.AudioSettingsPanel" Classes="settings-ui" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">

            <!-- Volume + Mute -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="14">
                    <TextBlock Text="Volume"
                               Classes="settings-section-header"
                               Margin="0,0,0,4"/>

                    <Grid ColumnDefinitions="160,*,70,90" RowDefinitions="Auto,10,Auto,10,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Master"  Classes="settings-field-label" VerticalAlignment="Center"/>
                        <Slider    Grid.Row="0" Grid.Column="1" x:Name="MasterVolumeSlider" Minimum="0" Maximum="1" Value="1" TickFrequency="0.05" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" x:Name="MasterVolumeLabel" Text="100%" Classes="settings-field-label" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="0" Grid.Column="3" x:Name="MasterMuteCheckBox" Content="Mute" Classes="settings-field-label" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Music"  Classes="settings-field-label" VerticalAlignment="Center"/>
                        <Slider    Grid.Row="2" Grid.Column="1" x:Name="MusicVolumeSlider"  Minimum="0" Maximum="1" Value="0.7" TickFrequency="0.05" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="MusicVolumeLabel" Text="70%" Classes="settings-field-label" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="2" Grid.Column="3" x:Name="MusicMuteCheckBox" Content="Mute" Classes="settings-field-label" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="SFX"    Classes="settings-field-label" VerticalAlignment="Center"/>
                        <Slider    Grid.Row="4" Grid.Column="1" x:Name="SfxVolumeSlider"    Minimum="0" Maximum="1" Value="0.9" TickFrequency="0.05" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="SfxVolumeLabel" Text="90%" Classes="settings-field-label" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="4" Grid.Column="3" x:Name="SfxMuteCheckBox" Content="Mute" Classes="settings-field-label" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="220,160,*">
                        <TextBlock Grid.Column="0" Text="Music track crossfade (ms)" Classes="settings-field-label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Column="1" x:Name="MusicCrossfadeMsBox" Minimum="0" Maximum="10000" Increment="50" Value="1000"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- State → Music mapping -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="State → Music"
                               Classes="settings-section-header"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Choose which music cue plays in each game state."
                               Classes="settings-muted" FontSize="12"/>
                    <ItemsControl x:Name="StateMusicMapItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Cue grid -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Cue bindings"
                               Classes="settings-section-header"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Each cue can map to a WAV / MP3 / FLAC file under GameData/Audio/. OGG requires the SoundFlow FFmpeg extension. Test plays the cue immediately."
                               Classes="settings-muted" FontSize="12" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="CueBindingItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

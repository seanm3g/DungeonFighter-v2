<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.ItemAffixesSettingsPanel"
             Classes="settings-ui"
             Background="Transparent">
    <TabControl x:Name="AffixesTabControl">
        <TabItem Header="Prefixes">
            <ContentControl x:Name="PrefixesHost"/>
        </TabItem>
        <TabItem Header="Suffixes">
            <ContentControl x:Name="SuffixesHost"/>
        </TabItem>
    </TabControl>
</UserControl>

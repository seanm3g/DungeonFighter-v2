<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.TravelSettingsPanel" Classes="settings-ui" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <StackPanel Spacing="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Travel"
                               Classes="settings-section-header"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Each trip rolls 4d4 once to decide how many travel events (d20 rolls) occur. Travel time multiplier scales the pause after each revealed step and the journey minutes in the summary. The per-roll pacing curve (base delay at natural 20 and extra per point below 20) is configured under Settings → Text Delays → Region travel (per d20 roll). Use 0 for no wait between steps; 1 is default pacing for the multiplier."
                               Classes="settings-muted"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Classes="settings-field-label"
                                   FontSize="14"
                                   Text="Travel time multiplier"
                                   Margin="0,0,12,0"/>
                        <TextBox x:Name="TravelTimeMultiplierTextBox"
                                 Grid.Row="0" Grid.Column="1"
                                 Width="140"
                                 HorizontalAlignment="Left"
                                 Watermark="e.g. 1 or 0.5"/>
                    </Grid>
                    <TextBlock Text="Allowed range after save: 0 through 5. Values are clamped if out of range."
                               Classes="settings-muted"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

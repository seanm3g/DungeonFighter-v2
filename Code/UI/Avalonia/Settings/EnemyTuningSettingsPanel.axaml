<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:RPGGame.UI.Avalonia.Components"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.EnemyTuningSettingsPanel"
             Background="Transparent">
    <UserControl.Resources>
        <SolidColorBrush x:Key="EnemyTuningBodyBrush" Color="#FFF5F5F5"/>
        <SolidColorBrush x:Key="EnemyTuningMutedBrush" Color="#FFE0E0E0"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="TextBox.SpawnPctBox">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Styles>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <Border Background="#FF252525"
                    BorderBrush="#FF404040"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Enemy tuning"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EnemyTuningBodyBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="These scales apply to every enemy built from Enemies.json (after archetype baselines and before global health/damage/armor/speed multipliers). Values are saved to TuningConfig.json under enemySystem.progressionScales."
                               Foreground="{StaticResource EnemyTuningBodyBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <!-- Captions are separate TextBlocks so Fluent theme cannot hide the slider row label. -->
                    <Border Background="#FF383838"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Base health scale"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <components:SliderWithTextBox x:Name="EnemyBaseHealthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Health per level scale"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <components:SliderWithTextBox x:Name="EnemyHealthGrowthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Attribute growth scale (STR / AGI / TEC / INT per level)"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <components:SliderWithTextBox x:Name="EnemyAttributeGrowthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Use Save at the bottom of Settings to write TuningConfig.json. New enemies spawned after that use the updated curves."
                               Foreground="{StaticResource EnemyTuningMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="#FF252525"
                    BorderBrush="#FF404040"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Enemy spawn tier weights"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EnemyTuningBodyBrush}"/>
                    <TextBlock Text="Percent chance for each spawn tier roll (should total 100% per tab). Values are saved under enemySystem.spawnTierWeightsBySettlement. Settlement type is chosen from the room location name (city / town / village), the region's settlementType in Regions.json, or tuning overrides."
                               Foreground="{StaticResource EnemyTuningBodyBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <TabControl MinHeight="320">
                        <TabItem Header="Rural">
                            <StackPanel Spacing="10" Margin="8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Common" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="RuralCommonPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Uncommon (biome)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="RuralUncommonBiomePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Uncommon (region)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="RuralUncommonRegionPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Uncommon (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="RuralUncommonLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rare (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="RuralRareLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Anywhere" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="RuralAnywherePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" x:Name="RuralTotalLabel"
                                               Foreground="{StaticResource EnemyTuningMutedBrush}" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Town">
                            <StackPanel Spacing="10" Margin="8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Common" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TownCommonPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Uncommon (biome)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TownUncommonBiomePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Uncommon (region)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TownUncommonRegionPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Uncommon (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TownUncommonLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rare (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TownRareLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Anywhere" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="TownAnywherePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" x:Name="TownTotalLabel"
                                               Foreground="{StaticResource EnemyTuningMutedBrush}" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="City">
                            <StackPanel Spacing="10" Margin="8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Common" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="CityCommonPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Uncommon (biome)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CityUncommonBiomePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Uncommon (region)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="CityUncommonRegionPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Uncommon (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="CityUncommonLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rare (location)" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="CityRareLocationPercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Anywhere" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="CityAnywherePercent" Classes="SpawnPctBox"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" x:Name="CityTotalLabel"
                                               Foreground="{StaticResource EnemyTuningMutedBrush}" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    <TextBlock Text="Totals that are not exactly 100% are proportionally normalized when you save."
                               Foreground="{StaticResource EnemyTuningMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:RPGGame.UI.Avalonia.Components"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.EnemyTuningSettingsPanel"
             Background="Transparent">
    <UserControl.Resources>
        <SolidColorBrush x:Key="EnemyTuningBodyBrush" Color="#FFF5F5F5"/>
        <SolidColorBrush x:Key="EnemyTuningMutedBrush" Color="#FFE0E0E0"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <Border Background="#FF252525"
                    BorderBrush="#FF404040"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Enemy tuning"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EnemyTuningBodyBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="These scales apply to every enemy built from Enemies.json (after archetype baselines and before global health/damage/armor/speed multipliers). Values are saved to TuningConfig.json under enemySystem.progressionScales."
                               Foreground="{StaticResource EnemyTuningBodyBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <!-- Captions are separate TextBlocks so Fluent theme cannot hide the slider row label. -->
                    <Border Background="#FF383838"
                            BorderBrush="#FF555555"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Base health scale"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <components:SliderWithTextBox x:Name="EnemyBaseHealthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Health per level scale"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <components:SliderWithTextBox x:Name="EnemyHealthGrowthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Attribute growth scale (STR / AGI / TEC / INT per level)"
                                           Foreground="#FFFFFFFF"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <components:SliderWithTextBox x:Name="EnemyAttributeGrowthScaleControl"
                                                             ShowLabel="False"
                                                             Label=""
                                                             Minimum="0.25"
                                                             Maximum="3.0"
                                                             Value="1.0"
                                                             TickFrequency="0.05"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Use Save at the bottom of Settings to write TuningConfig.json. New enemies spawned after that use the updated curves."
                               Foreground="{StaticResource EnemyTuningMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

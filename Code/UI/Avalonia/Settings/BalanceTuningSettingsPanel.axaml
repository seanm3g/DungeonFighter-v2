<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.BalanceTuningSettingsPanel" Classes="settings-ui" Background="Transparent">
    <!-- Fluent theme hover can wash out custom colors on this light panel; keep visible hover states. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <!-- Header -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="Balance Tuning (Import)" 
                               Classes="settings-panel-title" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Pull or push from one spreadsheet: use the same published CSV base link for Actions, then optional numeric tab gids (from File → Share → Publish to web for each tab). OAuth push needs the browser Edit link so spreadsheetId is valid (publish-only e/2PACX links are not enough)." 
                               FontSize="14" 
                               Classes="settings-muted" 
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Google Sheets -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Google Sheets"
                               Classes="settings-section-header"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Spreadsheet edit link (for push / OAuth — copy from the browser address bar; must look like …/spreadsheets/d/&lt;long-id&gt;/edit…)"
                               FontSize="12"
                               Classes="settings-muted"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="SpreadsheetEditUrlTextBox"
                             MinHeight="28"
                             Watermark="https://docs.google.com/spreadsheets/d/…/edit…"
                             FontSize="14"
                             Padding="8"/>
                    <Button x:Name="OpenSpreadsheetEditUrlButton"
                            Content="Open spreadsheet in browser"
                            HorizontalAlignment="Left"
                            MinHeight="28"
                            FontSize="13"
                            Padding="12,4"
                            Cursor="Hand"/>
                    <TextBlock Text="Actions tab — published CSV URL (same link pattern for all tabs; only gid= changes per tab)"
                               FontSize="12"
                               Classes="settings-muted"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                    <TextBox x:Name="ActionsSheetUrlTextBox"
                             MinHeight="28"
                             Watermark="https://docs.google.com/spreadsheets/..."
                             FontSize="14"
                             Padding="8"/>
                    <Expander Header="Other tabs (same spreadsheet as Actions URL)" IsExpanded="False">
                        <StackPanel Spacing="10" Margin="0,8,0,0">
                            <TextBlock Text="Enter each tab’s numeric gid from Publish to web (same document as Actions). Leave empty to skip that tab. Advanced: set full per-tab URLs in SheetsConfig.json."
                                       FontSize="12"
                                       Classes="settings-muted"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="WEAPONS → Weapons.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="WeaponsTabGidTextBox" MinHeight="28" Watermark="e.g. 1234567890" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="Prefix (sheet tab) → Modifications.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="ModificationsTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="ARMOR → Armor.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="ArmorTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="SUFFIXES (item suffixes) → StatBonuses.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="StatBonusesTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="CONSUMABLES → Consumables.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="ConsumablesTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="ENEMIES → Enemies.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="EnemiesTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="ENVIRONMENTS → Rooms.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="EnvironmentsTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="CLASSES → classPresentation in TuningConfig.json" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="ClassPresentationTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                            <TextBlock Text="CLASS ACTIONS → ClassActions.json (tier / class / action)" FontSize="12" Classes="settings-muted"/>
                            <TextBox x:Name="ClassActionsTabGidTextBox" MinHeight="28" Watermark="gid" FontSize="13" Padding="8" BorderThickness="1"/>
                        </StackPanel>
                    </Expander>
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                            <TextBlock Text="Include spreadsheet tabs (Pull and Push)"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Classes="settings-field-label"/>
                            <TextBlock Text="Only checked tabs are pulled from published CSV URLs or pushed via OAuth. Unchecked tabs are left unchanged on disk and on the sheet. Selections are saved to SheetsPushConfig.json when that file exists."
                                       FontSize="11"
                                       Classes="settings-muted"
                                       TextWrapping="Wrap"/>
                            <WrapPanel Orientation="Horizontal">
                                <CheckBox x:Name="PushActionsTabCheckBox" Content="ACTIONS" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushWeaponsTabCheckBox" Content="WEAPONS" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushModificationsTabCheckBox" Content="PREFIX" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushArmorTabCheckBox" Content="ARMOR" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushStatBonusesTabCheckBox" Content="SUFFIXES" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushConsumablesTabCheckBox" Content="CONSUMABLES" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushEnemiesTabCheckBox" Content="ENEMIES" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushEnvironmentsTabCheckBox" Content="ENVIRONMENTS" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushDungeonsTabCheckBox" Content="DUNGEONS" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushClassPresentationTabCheckBox" Content="CLASSES" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                                <CheckBox x:Name="PushClassActionsTabCheckBox" Content="CLASS ACTIONS" IsChecked="True" Margin="0,0,16,6" Classes="settings-field-label"/>
                            </WrapPanel>
                        </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ResyncSheetsButton"
                                Content="PULL from Google Sheets"
                                Width="260"
                                Height="35"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#FF0078D4"
                                BorderThickness="0"
                                CornerRadius="4"
                                Cursor="Hand"/>
                        <Button x:Name="PushSheetsButton"
                                Content="Push game data to Google Sheets"
                                Width="280"
                                Height="35"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#FFC50E1F"
                                BorderThickness="0"
                                CornerRadius="4"
                                Cursor="Hand"/>
                    </StackPanel>
                    <TextBlock x:Name="SheetsSyncProgressTextBlock"
                               Text="Ready"
                               FontSize="13"
                               Classes="settings-muted"/>
                    <ScrollViewer MaxHeight="160"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="SheetsSyncOutputTextBox"
                                 IsReadOnly="True"
                                 Focusable="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

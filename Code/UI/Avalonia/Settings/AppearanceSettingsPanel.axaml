<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:RPGGame.UI.Avalonia.Settings"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.AppearanceSettingsPanel" Classes="settings-ui" Background="Transparent">
    <TabControl x:Name="AppearanceTabControl">
        <TabItem Header="Settings UI">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="12" Margin="20">
                    <TextBlock Text="Colors for the settings window chrome (sidebar, title, buttons, and inputs)."
                               Classes="settings-muted"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                        <!-- Panel Colors -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Panel Colors" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Rows="1">
                                <!-- Panel Background -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Panel Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PanelBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FFFFFFFF"/>
                                        <Border x:Name="PanelBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="White"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Panel Border -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Panel Border:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PanelBorderTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF404040"/>
                                        <Border x:Name="PanelBorderPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderBrush="#FF404040"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Panel Text -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Panel Text:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PanelTextTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF000000"/>
                                        <Border x:Name="PanelTextPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Black"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Aa" 
                                                       Classes="settings-field-label"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                        
                        <!-- Divider -->
                        <Border Height="1" Background="#FFE0E0E0" Margin="0,8,0,8"/>
                        
                        <!-- Settings Window Colors -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Settings Window Colors" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <UniformGrid Columns="2" Rows="1">
                                <!-- Window Background -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Window Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SettingsBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF1A1A1A"/>
                                        <Border x:Name="SettingsBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF1A1A1A"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Title Color -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Title Color:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SettingsTitleTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FFD700"/>
                                        <Border x:Name="SettingsTitlePreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Title" 
                                                       Foreground="#FFD700"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                        
                        <!-- Divider -->
                        <Border Height="1" Background="#FFE0E0E0" Margin="0,8,0,8"/>
                        
                        <!-- Navigation List Colors -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Navigation List Colors" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Rows="1">
                                <!-- Selected Text -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Selected Text:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ListBoxSelectedTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FFD700"/>
                                        <Border x:Name="ListBoxSelectedPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Selected" 
                                                       Foreground="#FFD700"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Selected Background -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Selected Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ListBoxSelectedBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF2A2A2A"/>
                                        <Border x:Name="ListBoxSelectedBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Hover Background -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Hover Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ListBoxHoverBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF353535"/>
                                        <Border x:Name="ListBoxHoverBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF353535"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                        
                        <!-- Divider -->
                        <Border Height="1" Background="#FFE0E0E0" Margin="0,8,0,8"/>
                        
                        <!-- Text Input Colors -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Text Input Colors" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Rows="2">
                                <!-- Text Color -->
                                <StackPanel Spacing="5" Margin="0,0,12,10">
                                    <TextBlock Text="Text Color:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBoxTextColorTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 SelectionBrush="#FF0078D4"
                                                 SelectionForegroundBrush="White"
                                                 Text="#FFFFFF"/>
                                        <Border x:Name="TextBoxTextColorPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Aa" 
                                                       Foreground="#FFFFFF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Background -->
                                <StackPanel Spacing="5" Margin="0,0,12,10">
                                    <TextBlock Text="Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBoxBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF2A2A2A"/>
                                        <Border x:Name="TextBoxBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Hover Background -->
                                <StackPanel Spacing="5" Margin="0,0,0,10">
                                    <TextBlock Text="Hover Background:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBoxHoverBackgroundTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF353535"/>
                                        <Border x:Name="TextBoxHoverBackgroundPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF353535"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Border Color -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Border Color:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBoxBorderTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF555555"/>
                                        <Border x:Name="TextBoxBorderPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Focus Border -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Focus Border:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TextBoxFocusBorderTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF0078D4"/>
                                        <Border x:Name="TextBoxFocusBorderPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="Transparent"
                                                BorderBrush="#FF0078D4"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Empty cell for alignment -->
                                <StackPanel Spacing="5"/>
                            </UniformGrid>
                        </StackPanel>
                        
                        <!-- Divider -->
                        <Border Height="1" Background="#FFE0E0E0" Margin="0,8,0,8"/>
                        
                        <!-- Button Colors -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Button Colors" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Rows="1">
                                <!-- Primary Button -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Primary Button:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ButtonPrimaryTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF0078D4"/>
                                        <Border x:Name="ButtonPrimaryPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF0078D4"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Secondary Button -->
                                <StackPanel Spacing="5" Margin="0,0,12,0">
                                    <TextBlock Text="Secondary Button:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ButtonSecondaryTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF555555"/>
                                        <Border x:Name="ButtonSecondaryPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF555555"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                
                                <!-- Back Button -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Back Button:" 
                                               Classes="settings-field-label" 
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ButtonBackTextBox" 
                                                 Grid.Column="0"
                                                 Height="28"
                                                 BorderThickness="1"
                                                 Padding="6,4"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Text="#FF404040"/>
                                        <Border x:Name="ButtonBackPreview"
                                                Grid.Column="1"
                                                Width="55"
                                                Height="28"
                                                Background="#FF404040"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Color Codes">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <settings:ColorCodesSettingsPanel Margin="20"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Templates">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <settings:ColorTemplatesSettingsPanel Margin="20"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Keywords">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <settings:KeywordGroupsSettingsPanel Margin="20"/>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Combat Text">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="12" Margin="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Subsequent Line Darkening" 
                                       FontSize="17" 
                                       FontWeight="SemiBold" 
                                       Classes="settings-field-label" 
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Controls how much darker subsequent lines (roll info, status effects) appear compared to the primary action line. Lower values = darker, higher values = brighter. Default: 0.8 (20% darker)" 
                                       Classes="settings-muted"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SubsequentLineDarkeningSlider"
                                        Grid.Column="0"
                                        Minimum="0.0"
                                        Maximum="1.0"
                                        Value="0.8"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="True"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"/>
                                <TextBox x:Name="SubsequentLineDarkeningTextBox"
                                         Grid.Column="1"
                                         Height="28"
                                         BorderThickness="1"
                                         Padding="6,4"
                                         FontSize="14"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"
                                         Text="0.8"/>
                                <TextBlock Grid.Column="2"
                                           Text="(0.0-1.0)"
                                           Classes="settings-muted"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        
                        <Border Height="1" Background="#FFE0E0E0" Margin="0,8,0,8"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Animated text brightness (canvas)"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Classes="settings-field-label"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Bounds HSV Value (0–255 scale, V = max RGB / 255) for shimmering / undulating canvas text — hue and saturation stay the same; only Value is raised or capped. Higher minimum = brighter floor for dark letters; lower maximum = dimmer peaks."
                                       FontSize="12"
                                       Foreground="#FF666666"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Minimum:"
                                           VerticalAlignment="Center"
                                           Classes="settings-field-label"
                                           FontSize="14"
                                           Margin="0,0,14,10"/>
                                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,100,50">
                                    <Slider x:Name="AnimatedTextBrightnessMinSlider"
                                            Grid.Column="0"
                                            Minimum="0"
                                            Maximum="255"
                                            Value="0"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"/>
                                    <TextBox x:Name="AnimatedTextBrightnessMinTextBox"
                                             Grid.Column="1"
                                             Height="28"
                                             BorderThickness="1"
                                             Padding="6,4"
                                             FontSize="14"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             Text="0"/>
                                    <TextBlock Grid.Column="2"
                                               Text="0–255"
                                               FontSize="12"
                                               Foreground="#FF666666"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Maximum:"
                                           VerticalAlignment="Center"
                                           Classes="settings-field-label"
                                           FontSize="14"
                                           Margin="0,0,14,0"/>
                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,100,50">
                                    <Slider x:Name="AnimatedTextBrightnessMaxSlider"
                                            Grid.Column="0"
                                            Minimum="0"
                                            Maximum="255"
                                            Value="255"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"/>
                                    <TextBox x:Name="AnimatedTextBrightnessMaxTextBox"
                                             Grid.Column="1"
                                             Height="28"
                                             BorderThickness="1"
                                             Padding="6,4"
                                             FontSize="14"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             Text="255"/>
                                    <TextBlock Grid.Column="2"
                                               Text="0–255"
                                               FontSize="12"
                                               Foreground="#FF666666"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>

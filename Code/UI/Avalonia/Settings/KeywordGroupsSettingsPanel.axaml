<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.KeywordGroupsSettingsPanel" Classes="settings-ui" Background="Transparent">
    <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">
            <!-- Buttons -->
            <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <Button x:Name="AddKeywordGroupButton"
                        Grid.Column="0"
                        Content="+ Add Group"
                        HorizontalAlignment="Left"
                        Padding="10,5"
                        Background="#FF28A745"
                        BorderThickness="0"
                        CornerRadius="4"
                        FontSize="11"
                        Cursor="Hand"/>
                <Button x:Name="SaveKeywordColorsButton"
                        Grid.Column="1"
                        Content="Save"
                        HorizontalAlignment="Right"
                        Padding="10,5"
                        Background="#FF0078D4"
                        BorderThickness="0"
                        CornerRadius="4"
                        FontSize="11"
                        Cursor="Hand"/>
            </Grid>
            <!-- Dropdown -->
            <Border Grid.Column="0" Grid.Row="1" 
                    BorderBrush="#555555" 
                    BorderThickness="0,1,1,0"
                    Margin="0,0,5,0"
                    VerticalAlignment="Top">
                <ComboBox x:Name="KeywordsComboBox"
                        Padding="5"
                        Margin="0,5,0,0"/>
            </Border>
            <!-- Editor -->
            <ScrollViewer Grid.Column="1" Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto"
                         Padding="10,10,10,20">
                <StackPanel x:Name="KeywordEditorPanel" Spacing="5"/>
            </ScrollViewer>
        </Grid>
</UserControl>

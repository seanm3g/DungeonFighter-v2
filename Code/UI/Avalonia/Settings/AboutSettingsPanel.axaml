<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.AboutSettingsPanel"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <!-- Game Information -->
            <Border Background="White" 
                    BorderBrush="#FF404040" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="DungeonFighter v2" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="Black" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock x:Name="VersionSubtitleTextBlock"
                               FontSize="18" 
                               Foreground="#FFAAAAAA" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    
                    <TextBlock Text="A turn-based RPG/dungeon crawler with deep combat systems, readable battle narration, and tuning that lives in JSON so content and balance can evolve without rebuilding core code." 
                               FontSize="15" 
                               Foreground="Black" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>
                    
                    <Separator Background="#FF555555" Margin="0,10,0,10"/>
                    
                    <TextBlock Text="Key Features:" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="Black" 
                               Margin="0,0,0,10"/>
                    
                    <StackPanel Spacing="8" Margin="10,0,0,0">
                        <TextBlock Text="• Turn-based combat with combos, routing, and rich action interactions" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• Dice-driven resolution with thresholds, modifiers, and conditional triggers" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• Narrative layer for notable moments plus clear summaries for routine play" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• In-app settings for classes, balance, items, appearance, and import/testing tools" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• JSON-first game data with optional Google Sheets pull/push workflows" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Technical Information -->
            <Border Background="White" 
                    BorderBrush="#FF404040" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="Technical Information" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="Black" 
                               Margin="0,0,0,10"/>
                    
                    <StackPanel Spacing="8" Margin="10,0,0,0">
                        <TextBlock Text="• Avalonia 11.x desktop UI (Windows, macOS, Linux)" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• C# on .NET 8" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• Modular architecture: gameplay, data, and UI boundaries stay explicit" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• Automated tests across parsers, progression, and data pipelines" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                        <TextBlock Text="• MCP (Model Context Protocol) integration for external agent/tooling workflows" 
                                   FontSize="15" 
                                   Foreground="Black"/>
                    </StackPanel>
                    <Separator Background="#FF555555" Margin="0,10,0,10"/>
                    <TextBlock Text="Settings file (load/save):" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="Black"/>
                    <TextBlock x:Name="SettingsFilePathTextBlock"
                               FontSize="12" 
                               Foreground="#FF555555" 
                               TextWrapping="Wrap"
                               Text=""/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


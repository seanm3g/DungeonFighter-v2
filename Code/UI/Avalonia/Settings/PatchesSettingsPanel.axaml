<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.PatchesSettingsPanel" Classes="settings-ui" Background="Transparent">
    <UserControl.Styles>
        <!-- Popup overlay can miss global .settings-ui ancestry; keep patch controls readable everywhere -->
        <Style Selector="ComboBox /template/ Border#PopupBorder">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>
        <Style Selector="ComboBox:dropdownopen /template/ Border#PopupBorder">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="#FF353535"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF353535"/>
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="#FF2F65B2"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2F65B2"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#FF6A6A6A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:pointerover /template/ Border#RootBorder">
            <Setter Property="Background" Value="#FF6A6A6A"/>
        </Style>
        <Style Selector="Button:pointerover /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#FF6A6A6A"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" Margin="20">

            <StackPanel Spacing="8">
                <TextBlock Text="Config patches"
                           Classes="settings-section-header"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Gameplay, UI, and volume live in local GeneralSettings.json. Audio and balance patches are chosen below; the first-run default is written to ShippedPatchDefaults.json for new installs."
                           Classes="settings-muted"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Active selection -->
            <StackPanel Spacing="12">
                <TextBlock Text="Active selection"
                           Classes="settings-section-header"
                           Margin="0,0,0,4"/>
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="settings-field-label" Text="General settings" Margin="0,0,0,10"/>
                    <TextBlock x:Name="GameSettingsPatchLabel" Grid.Row="0" Grid.Column="1" Classes="settings-muted" Text="Local only" VerticalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="settings-field-label" Text="Audio / music" Margin="0,0,0,10"/>
                    <ComboBox x:Name="AudioPatchCombo" Grid.Row="1" Grid.Column="1" MinWidth="280" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="settings-field-label" Text="Balance" Margin="0,0,0,10"/>
                    <ComboBox x:Name="BalancePatchCombo" Grid.Row="2" Grid.Column="1" MinWidth="280" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ApplyPatchesButton" Content="Apply selection" MinWidth="130"/>
                        <Button x:Name="RefreshPatchesButton" Content="Refresh list" MinWidth="110"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- First-run default -->
            <StackPanel Spacing="12">
                <TextBlock Text="First-run default"
                           Classes="settings-section-header"
                           Margin="0,0,0,4"
                           ToolTip.Tip="Shipped default for players with no PatchProfile.json yet (new download / first run). Tracked in GameData/ShippedPatchDefaults.json."/>
                <TextBlock Text="Balance patch new installs get when no PatchProfile.json exists yet. Does not change your current active selection."
                           Classes="settings-muted"
                           TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="160,*">
                    <TextBlock Grid.Column="0" Classes="settings-field-label" Text="Balance patch" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <ComboBox x:Name="ShippedDefaultBalanceCombo" MinWidth="280" HorizontalAlignment="Left"
                                  ToolTip.Tip="Balance patch new players get on first run. Does not change your current active selection until you Apply above."/>
                        <Button x:Name="SetShippedDefaultBalanceButton" Content="Set shipped default" MinWidth="150"
                                ToolTip.Tip="Writes GameData/ShippedPatchDefaults.json (commit this so releases ship the chosen default)."/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Import / export -->
            <StackPanel Spacing="12">
                <TextBlock Text="Import / export"
                           Classes="settings-section-header"
                           Margin="0,0,0,4"/>
                <Grid ColumnDefinitions="160,*">
                    <TextBlock Grid.Column="0" Classes="settings-field-label" Text="Category" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <ComboBox x:Name="PatchIoCategoryCombo" MinWidth="140" SelectedIndex="0">
                            <ComboBoxItem Content="Audio / music"/>
                            <ComboBoxItem Content="Balance"/>
                        </ComboBox>
                        <Button x:Name="ImportPatchButton" Content="Import patch…" MinWidth="110"/>
                        <Button x:Name="ExportPatchButton" Content="Export patch…" MinWidth="110"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Active files -->
            <StackPanel Spacing="12">
                <TextBlock Text="Active files"
                           Classes="settings-section-header"
                           Margin="0,0,0,4"/>
                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="settings-muted" Text="General settings" Margin="0,0,0,6"/>
                    <TextBlock x:Name="GeneralSettingsPathLabel" Grid.Row="0" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="settings-muted" Text="Audio patch" Margin="0,0,0,6"/>
                    <TextBlock x:Name="AudioPatchPathLabel" Grid.Row="1" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="settings-muted" Text="Balance" Margin="0,0,0,6"/>
                    <TextBlock x:Name="BalancePatchPathLabel" Grid.Row="2" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="settings-muted" Text="First-run default" Margin="0,0,0,6"/>
                    <TextBlock x:Name="FirstRunDefaultPathLabel" Grid.Row="3" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="settings-muted" Text="Shipped defaults" Margin="0,0,0,6"/>
                    <TextBlock x:Name="ShippedDefaultsPathLabel" Grid.Row="4" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="settings-muted" Text="Profile"/>
                    <TextBlock x:Name="ProfilePathLabel" Grid.Row="5" Grid.Column="1" Classes="settings-muted" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

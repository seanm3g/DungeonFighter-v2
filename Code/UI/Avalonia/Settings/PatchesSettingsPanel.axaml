<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.PatchesSettingsPanel" Classes="settings-ui" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <StackPanel Spacing="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Config patches"
                               Classes="settings-section-header"/>
                    <TextBlock Text="General settings (gameplay, UI, volume) are stored locally in GeneralSettings.json and never uploaded. Default audio and balance patches update from GitHub on pull; named audio and balance patches stay local."
                               Classes="settings-muted"
                               FontSize="14"
                               TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Classes="settings-field-label" Text="General settings"/>
                        <TextBlock x:Name="GameSettingsPatchLabel" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Classes="settings-muted" Text="local only"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Classes="settings-field-label" Text="Audio / music" Margin="0,8,0,0"/>
                        <ComboBox x:Name="AudioPatchCombo" Grid.Row="1" Grid.Column="1" MinWidth="280" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Classes="settings-field-label" Text="Balance" Margin="0,8,0,0"/>
                        <ComboBox x:Name="BalancePatchCombo" Grid.Row="2" Grid.Column="1" MinWidth="280" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,16,0,0">
                            <ComboBox x:Name="PatchIoCategoryCombo" MinWidth="140" SelectedIndex="0">
                                <ComboBoxItem Content="Audio / music"/>
                                <ComboBoxItem Content="Balance"/>
                            </ComboBox>
                            <Button x:Name="ImportPatchButton" Content="Import patch…" MinWidth="110"/>
                            <Button x:Name="ExportPatchButton" Content="Export patch…" MinWidth="110"/>
                            <Button x:Name="RefreshPatchesButton" Content="Refresh list" MinWidth="110"/>
                            <Button x:Name="ApplyPatchesButton" Content="Apply selection" MinWidth="130"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="ActivePathsTextBlock"
                               Classes="settings-muted"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

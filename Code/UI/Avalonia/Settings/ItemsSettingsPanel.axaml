<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:RPGGame.UI.Avalonia.Settings"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.ItemsSettingsPanel" Classes="settings-ui" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <!-- Header -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="Item Management" 
                                       Classes="settings-panel-title" 
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Manage weapons and armor: add new items, edit existing ones, or delete them. Changes will be saved to Weapons.json and Armor.json when you click Save." 
                                       FontSize="14" 
                                       Foreground="#FF666666" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    Spacing="10"
                                    VerticalAlignment="Top">
                            <Button x:Name="AddWeaponButton"
                                    Content="Add Weapon"
                                    Width="120"
                                    Height="35"
                                    Background="#FF4CAF50"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"/>
                            <Button x:Name="AddArmorButton"
                                    Content="Add Armor"
                                    Width="120"
                                    Height="35"
                                    Background="#FF4CAF50"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"/>
                            <Button x:Name="EditItemButton"
                                    Content="Edit Selected"
                                    Width="120"
                                    Height="35"
                                    Background="#FF2196F3"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"
                                    IsEnabled="False"/>
                            <Button x:Name="DeleteItemButton"
                                    Content="Delete Selected"
                                    Width="120"
                                    Height="35"
                                    Background="#FFF44336"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Weapons Section -->
            <StackPanel Spacing="12" Margin="0,0,0,15">
                    <TextBlock Text="Weapons" 
                               Classes="settings-section-header" 
                               Margin="0,0,0,8"/>
                    <ItemsControl x:Name="WeaponsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="settings:ItemViewModel">
                                <Border Background="{Binding BackgroundColor}"
                                        BorderBrush="#FF404040"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,0,0,8"
                                        Cursor="Hand"
                                        PointerPressed="OnItemPointerPressed">
                                    <StackPanel Spacing="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}" 
                                                       FontSize="14" 
                                                       FontWeight="SemiBold"
                                                       Classes="settings-field-label"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       MinWidth="150"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Type}" 
                                                       FontSize="13" 
                                                       Foreground="#FF666666"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding WeaponDamageListText}"
                                                       FontSize="13"
                                                       Foreground="#FF666666"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,14,0"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding AttackSpeed, StringFormat='Speed: {0:F2}'}"
                                                       FontSize="13"
                                                       Foreground="#FF666666"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="Tier:" 
                                                       FontSize="13" 
                                                       Classes="settings-field-label"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <ComboBox Grid.Column="5"
                                                      SelectedItem="{Binding SelectedTier, Mode=TwoWay}"
                                                      ItemsSource="{Binding AvailableTiers}"
                                                      BorderThickness="1"
                                                      Padding="6,4"
                                                      FontSize="13"
                                                      VerticalAlignment="Center"
                                                      Width="80"
                                                      Margin="0,0,0,0">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock Text="{Binding TagsSummary, StringFormat='Tags: {0}'}"
                                                   FontSize="11"
                                                   Foreground="#FF888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding StarterSummary, StringFormat='Starter: {0}'}"
                                                   FontSize="11"
                                                   Foreground="#FF777777"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding ActionsSummary, StringFormat='Actions: {0}'}"
                                                   FontSize="11"
                                                   Foreground="#FF777777"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            <!-- Armor Section -->
            <StackPanel Spacing="12" Margin="0,0,0,15">
                    <TextBlock Text="Armor" 
                               Classes="settings-section-header" 
                               Margin="0,0,0,8"/>
                    <ItemsControl x:Name="ArmorItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="settings:ItemViewModel">
                                <Border Background="{Binding BackgroundColor}"
                                        BorderBrush="#FF404040"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,0,0,8"
                                        Cursor="Hand"
                                        PointerPressed="OnItemPointerPressed">
                                    <StackPanel Spacing="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}" 
                                                       FontSize="14" 
                                                       FontWeight="SemiBold"
                                                       Classes="settings-field-label"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       MinWidth="150"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Slot}" 
                                                       FontSize="13" 
                                                       Foreground="#FF666666"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="Tier:" 
                                                       FontSize="13" 
                                                       Classes="settings-field-label"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <ComboBox Grid.Column="3"
                                                      SelectedItem="{Binding SelectedTier, Mode=TwoWay}"
                                                      ItemsSource="{Binding AvailableTiers}"
                                                      BorderThickness="1"
                                                      Padding="6,4"
                                                      FontSize="13"
                                                      VerticalAlignment="Center"
                                                      Width="80"
                                                      Margin="0,0,10,0">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Details}" 
                                                       FontSize="13" 
                                                       Foreground="#FF666666"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="{Binding TagsSummary, StringFormat='Tags: {0}'}"
                                                   FontSize="11"
                                                   Foreground="#FF888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding StarterSummary, StringFormat='Starter: {0}'}"
                                                   FontSize="11"
                                                   Foreground="#FF777777"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

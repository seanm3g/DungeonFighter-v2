<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="400"
             x:Class="RPGGame.UI.Avalonia.Settings.ActionInteractionLabSettingsPanel"
             Background="Transparent">
    <Border Background="White"
            BorderBrush="#FF404040"
            BorderThickness="1"
            CornerRadius="6"
            Padding="20"
            Margin="0,0,0,12">
        <StackPanel Spacing="14">
            <TextBlock Text="Action Lab"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="Black"/>
            <TextBlock Text="Sandbox combat with catalog enemies and gear. Changes here do not affect your saved character until you apply lab gear from the lab UI."
                       FontSize="14"
                       Foreground="#FF555555"
                       TextWrapping="Wrap"
                       MaxWidth="720"/>
            <Button x:Name="ActionInteractionLabButton"
                    Content="Open Action Lab"
                    Width="280"
                    Height="40"
                    Background="#FF6B2C"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="4"
                    FontSize="14"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </Border>
</UserControl>

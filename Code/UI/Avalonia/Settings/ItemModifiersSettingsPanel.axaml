<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:RPGGame.UI.Avalonia.Settings"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.ItemModifiersSettingsPanel" Classes="settings-ui" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="20">
            <!-- Header -->
            <StackPanel Spacing="15">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="Item prefixes" 
                                       Classes="settings-panel-title" 
                                       Margin="0,0,0,8"/>
                            <TextBlock FontSize="14" 
                                       Foreground="#FF666666" 
                                       TextWrapping="Wrap"
                                       Text="Prefix lines from Modifications.json (adjective / material / quality dice rows). Use the Item suffixes tab for StatBonuses.json. Add, edit, or delete rows below; click Save in the settings footer to write Modifications.json."/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    Spacing="10"
                                    VerticalAlignment="Top">
                            <Button x:Name="AddModifierButton"
                                    Content="Add prefix"
                                    Width="120"
                                    Height="35"
                                    Background="#FF4CAF50"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"/>
                            <Button x:Name="EditModifierButton"
                                    Content="Edit Selected"
                                    Width="120"
                                    Height="35"
                                    Background="#FF2196F3"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"
                                    IsEnabled="False"/>
                            <Button x:Name="DeleteModifierButton"
                                    Content="Delete Selected"
                                    Width="120"
                                    Height="35"
                                    Background="#FFF44336"
                                    BorderThickness="0"
                                    CornerRadius="3"
                                    FontSize="13"
                                    Cursor="Hand"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Modifiers by Rarity -->
            <ItemsControl x:Name="RarityGroupsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:RarityGroupViewModel">
                        <StackPanel Spacing="12" Margin="0,0,0,15">
                                <TextBlock Text="{Binding RarityName}" 
                                           Classes="settings-section-header" 
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Modifiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="settings:ModifierViewModel">
                                            <Border Background="{Binding BackgroundColor}"
                                                    BorderBrush="#FF404040"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8"
                                                    Margin="0,0,0,8"
                                                    Cursor="Hand"
                                                    PointerPressed="OnModifierPointerPressed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="200"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               Classes="settings-field-label"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"
                                                               MinWidth="120"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Description}" 
                                                               FontSize="13" 
                                                               Foreground="#FF666666"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="Rarity:" 
                                                               FontSize="13" 
                                                               Classes="settings-field-label"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <ComboBox Grid.Column="3"
                                                              SelectedItem="{Binding SelectedRarity, Mode=TwoWay}"
                                                              ItemsSource="{Binding AvailableRarities}"
                                                              BorderThickness="1"
                                                              Padding="6,4"
                                                              FontSize="13"
                                                              VerticalAlignment="Center">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" FontSize="13"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>


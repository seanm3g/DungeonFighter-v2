<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="RPGGame.UI.Avalonia.Settings.ActionsSettingsPanel" Classes="settings-ui" Background="Transparent">
    <Grid Margin="20" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Middle: Filter and Actions List with its own scroll -->
        <Grid Grid.Column="0" VerticalAlignment="Stretch" RowDefinitions="Auto,*,Auto">
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Filter by type" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="RarityFilterComboBox"
                          PlaceholderText="Rarity (all)"/>
                <ComboBox x:Name="CategoryFilterComboBox"
                          PlaceholderText="Category (all)"/>
                <ComboBox x:Name="CadenceFilterComboBox"
                          PlaceholderText="Cadence (all)"/>
                <ComboBox x:Name="TagFilterComboBox"
                          PlaceholderText="Tag (all)"/>
            </StackPanel>
            <ListBox Grid.Row="1"
                     x:Name="ActionsListBox"
                     BorderThickness="1"
                     VerticalAlignment="Stretch"
                     MinHeight="0"/>
            <StackPanel Grid.Row="2" Margin="0,8,0,0" Spacing="4">
                <TextBlock Text="Selected action — runtime tags"
                           FontWeight="SemiBold"
                           FontSize="12"/>
                <TextBlock x:Name="SelectedActionTagsPreviewTextBlock"
                           Text="Select an action to see runtime tags."
                           FontSize="11"
                           Foreground="#FFCCCCCC"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Right: Action form with its own scroll -->
        <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*" VerticalAlignment="Stretch">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Spacing="10"
                        Margin="0,0,0,8">
                <Button x:Name="OpenActionsSheetButton"
                        Content="Open ACTIONS sheet"
                        MinHeight="32"
                        FontSize="13"
                        Padding="12,4"
                        Cursor="Hand"/>
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        Margin="0,0,0,12">
                <Button x:Name="CreateActionButton"
                        Content="Create"
                        Width="100"
                        Height="40"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#FF0078D4"
                        BorderThickness="0"
                        CornerRadius="4"/>
                <Button x:Name="DeleteActionButton"
                        Content="Delete"
                        Width="100"
                        Height="40"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#FFD32F2F"
                        BorderThickness="0"
                        CornerRadius="4"/>
            </StackPanel>
            <ScrollViewer Grid.Row="2"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalAlignment="Stretch">
                <StackPanel x:Name="ActionFormPanel"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>


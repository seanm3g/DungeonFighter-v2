<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="RPGGame.UI.Avalonia.Components.SettingsSection"
             Classes="settings-ui"
             Background="Transparent">
    <StackPanel Spacing="12" Margin="0,8,0,0">
        <Button x:Name="HeaderButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Cursor="Hand">
            <Button.Styles>
                <Style Selector="Button">
                    <Setter Property="Foreground" Value="{DynamicResource SettingsTextPrimary}"/>
                    <Setter Property="FontSize" Value="{DynamicResource SettingsFontSizeSection}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
                <Style Selector="Button:pointerover">
                    <Setter Property="Foreground" Value="{DynamicResource SettingsInputFocusBorder}"/>
                </Style>
            </Button.Styles>
        </Button>
        <ContentControl x:Name="ContentArea">
            <!-- Content set programmatically -->
        </ContentControl>
    </StackPanel>
</UserControl>

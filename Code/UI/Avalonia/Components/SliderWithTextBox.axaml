<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="60"
             x:Class="RPGGame.UI.Avalonia.Components.SliderWithTextBox"
             Classes="settings-ui"
             Background="Transparent"
             HorizontalAlignment="Stretch"
             MinWidth="0">
    <Grid HorizontalAlignment="Stretch" MinWidth="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="80"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock x:Name="LabelTextBlock"
                       Classes="settings-field-label"/>
            <Slider x:Name="ValueSlider"
                    VerticalAlignment="Center"
                    TickFrequency="0.1"/>
        </StackPanel>
        <TextBox x:Name="ValueTextBox"
                 Grid.Column="1"
                 Width="75"
                 Height="28"
                 Margin="5,0,0,0"
                 BorderThickness="1"
                 FontSize="14"
                 VerticalAlignment="Center"/>
    </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RPGGame.UI.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1728" d:DesignHeight="972"
        x:Class="RPGGame.UI.Avalonia.SettingsWindow"
        Classes="settings-ui"
        Icon="/UI/Avalonia/Assets/df_icon.ico"
        Title="Game Settings - DungeonFighter v2"
        Background="{DynamicResource SettingsBackground}"
        Width="1728" Height="972" MinWidth="1400" MinHeight="800"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        CanResize="True">
    <Grid Background="{DynamicResource SettingsBackground}" x:Name="MainGrid"/>
</Window>
